# BlackHoleDS / OPPENGROK Black Hole Simulation Lab
# .gitignore — secret hygiene, build artifacts, generated data, IDE noise
#
# Rules:
#   1. No secrets ever — every secret pattern is a positive (allow-listed) match
#      against well-known credential file names, never a substring match on code.
#   2. Build outputs and generated data are ignored. Curated examples are
#      allow-listed explicitly so legitimate research/data fixtures stay tracked.
#   3. Archives are ignored except for test fixtures that need to ship.

# -----------------------------------------------------------------------------
# Secrets and credentials
# -----------------------------------------------------------------------------
.env
.env.*
*.env

# Common credential file basenames (whole-name, not substring)
credentials
credentials.*
secrets
secrets.*
*-credentials.json
*-credentials.yml
*-credentials.yaml
*.credentials
*.secrets

# Tokens and API keys — match leading dot files and obvious basenames
.netrc
.npmrc
.pypirc
.htpasswd

# Cryptographic key material
*.pem
*.key
*.pfx
*.p12
*.jks
*.keystore
*.ppk
id_rsa
id_rsa.*
id_dsa
id_dsa.*
id_ecdsa
id_ecdsa.*
id_ed25519
id_ed25519.*

# Cloud provider credentials
.aws/
.gcp/
.azure/
gcp-service-account*.json
aws-credentials*
azure-credentials*

# Known leaked-secret prefixes (filenames or staged copies of leaked material)
ghp_*.txt
sk-*.txt
AKIA*.txt
AIza*.txt

# -----------------------------------------------------------------------------
# Orca / Codex / agent state
# -----------------------------------------------------------------------------
.orca/
orca-terminal-*
worktree-*.comment
agent-*.state
parallel-*.lock
.codex/

# Nested Orca worktree that is not part of the project source tree
Nautilus/

# -----------------------------------------------------------------------------
# C++ build artifacts
# -----------------------------------------------------------------------------
build/
build-*/
out/
dist/
install/
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll
*.exe
*.pdb
*.ilk
*.exp
*.map
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CMakeUserPresets.json
compile_commands.json
vcpkg_installed/
vcpkg-manifest.log
.ninja_*

# Visual Studio
.vs/
*.vcxproj.user
*.suo
*.sdf
*.opensdf
ipch/

# Xcode and other IDEs
*.xcodeproj/
*.xcworkspace/
DerivedData/

# Python (data science tooling)
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.eggs/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/

# Node (in case a small web dashboard is added)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Data exports (regenerable; curated examples allow-listed below)
# -----------------------------------------------------------------------------
exports/
sim-runs/
ensemble-*/
trajectories/
frames/
renders/
*.csv
*.tsv
*.parquet
*.feather
*.sqlite
*.sqlite3
*.db
*.pbix
*.pbit
*.xlsx
*.xlsm
*.xls
# PowerBI / Excel temporary files
~$*.xlsx
~$*.xlsm

# Allow-list: curated examples and test fixtures must stay tracked
!examples/**/*.csv
!examples/**/*.db
!examples/**/*.xlsx
!tests/data/**/*.csv
!tests/fixtures/**/*.sqlite
!assets/charts/*.csv
!data/research/*.csv
!data/research/*.json
!docs/**/*.csv

# Generated visualization frames
diagrams/*.png
diagrams/*.svg
diagrams/*.pdf
!docs/**/*.svg
!docs/**/*.png
!assets/diagrams/*.svg
!assets/diagrams/*.mmd

# -----------------------------------------------------------------------------
# IDE, editor, OS noise
# -----------------------------------------------------------------------------
.idea/
*.iml
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.bak

# Patch files and diffs from local tools
*.patch
*.diff

# Local logs
*.log
logs/

# -----------------------------------------------------------------------------
# Incoming package staging
# -----------------------------------------------------------------------------
_incoming/
archives/

# -----------------------------------------------------------------------------
# Audit and scan outputs (artifacts, not source)
# -----------------------------------------------------------------------------
secret-scan-*.json
audit-*.raw
gitleaks-report*.json

# -----------------------------------------------------------------------------
# Version control hygiene
# -----------------------------------------------------------------------------
.git-credentials
.gitconfig.local

# Archives — most are intake artifacts, not source
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
!tests/fixtures/*.zip

# -----------------------------------------------------------------------------
# Generated documentation (kept regenerable)
# -----------------------------------------------------------------------------
docs/generated/
docs/_build/

# CI/CD artifacts
.github/workflows/*-local*
ci-artifacts/
junit/
coverage/
lcov.info
.nyc_output/

# Scheduler and daemon state
scheduler-*.state
daemon-*.pid
cron-*.lock
